<UserControl x:Class="MyFromToUseControlTraining.MyUseControlForPassword"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MyFromToUseControlTraining"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="300">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FFEAFFE1"/>
                <GradientStop Color="#FF12A1FF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <DockPanel LastChildFill="True">
            <Label x:Name="labeld"  Content="f" HorizontalAlignment="Right" VerticalAlignment="Center" VerticalContentAlignment="Bottom"/>
            <!--<TextBox x:Name="passwordBox" Text=""  TextWrapping="Wrap"  VerticalAlignment="Center" Width="166" HorizontalAlignment="Center"/> -->
            <PasswordBox x:Name="passwordBox" Width="200"  HorizontalAlignment="Center"  VerticalAlignment="Center" PasswordChar="●" Password="sddsds"/>
            <Button x:Name="visPassword"  Content="Покеж" Background="#FF67C4FF" Width="60" VerticalAlignment="Center" Click="visPassword_Click" HorizontalAlignment="Left" />
        </DockPanel>

    </Grid>
</UserControl>
