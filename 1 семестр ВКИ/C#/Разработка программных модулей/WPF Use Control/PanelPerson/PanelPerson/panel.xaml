<UserControl x:Class="PanelPerson.panel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PanelPerson"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="590">
    <Grid Background="White">
        <StackPanel >
            <Button Content="изменить" Width="64" Margin="10, 2,-500,10" Height="21" Click="EditButtonClick"/>
            <Button Content="удалить" Width="65" Margin="10, -5,-500,0" Height="20" Click="DeleteButtonClick"/>
            
            <TextBox x:Name="firstNameTextBox" TextWrapping="Wrap" Text="Имя" Width="92" Height="28" Margin="-20, -30,390,0"/>
            <TextBox x:Name="lastNameTextBox"  TextWrapping="Wrap" Text="Фамилия" Width="146" Height="28" Margin="-20, -30,140,0"/>
            <TextBox x:Name="middleNameTextBox"  TextWrapping="Wrap" Text="Отчество" Width="146" Height="28" Margin="-20, -30,-180,0"/>
            <TextBox x:Name="ID" TextWrapping="Wrap" Text="ID" Width="34" Height="28" Margin="-20, -30,530,0"/>
            <TextBox x:Name="ageTextBox" TextWrapping="Wrap" Text="Age" Width="39" Height="28" Margin="-20, -30,-400,0"/>



        </StackPanel>
    </Grid>
</UserControl>
