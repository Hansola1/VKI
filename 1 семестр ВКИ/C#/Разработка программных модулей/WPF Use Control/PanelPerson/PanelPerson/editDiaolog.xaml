<Window x:Class="PanelPerson.editDiaolog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PanelPerson"
        mc:Ignorable="d"
        Title="editDiaolog" Height="270" Width="170">
    <Grid>
        <Label Content="ID" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
        <Label Content="Фамилия" HorizontalAlignment="Left" Margin="4,58,0,0" VerticalAlignment="Top"/>
        <Label Content="Отчество" HorizontalAlignment="Left" Margin="3,153,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.451,0.543"/>
        <Label Content="Возраст" HorizontalAlignment="Left" Margin="84,10,0,0" VerticalAlignment="Top"/>
        <Label Content="Имя" HorizontalAlignment="Left" Margin="4,106,0,0" VerticalAlignment="Top"/>
        <Button Content="Сохранить" HorizontalAlignment="Left" Margin="7,208,0,0" VerticalAlignment="Top" Height="39" Width="153" Click="save_Click"/>


        <TextBox x:Name="IDTextBox" HorizontalAlignment="Left" Margin="10,36,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="43" Height="22"/>
        <TextBox x:Name="LastnameTextBox" HorizontalAlignment="Left" Margin="7,79,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="155" Height="22"/>
        <TextBox x:Name="NamePTextBox" HorizontalAlignment="Left" Margin="7,126,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="155" Height="22"/>
        <TextBox x:Name="FathernameTextBox" HorizontalAlignment="Left" Margin="7,172,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="155" Height="22"/>
        <TextBox x:Name="AgeTextBox" HorizontalAlignment="Left" Margin="84,36,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="51" Height="22"/>
    </Grid>
</Window>
