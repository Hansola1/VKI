<Window x:Class="PanelPerson.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PanelPerson"
        mc:Ignorable="d"
        Title="PersonEditApp" Height="400" Width="600">
    <Grid>
        <Button Content="Добавить" HorizontalAlignment="Left" Margin="300,14,0,0" VerticalAlignment="Top" Height="41" Width="150" Click="get_Click"/>
        <Label Content="Всего записей:" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="90"/>
        <Label Content="Сумма лет:" HorizontalAlignment="Left" Margin="10,33,0,0" VerticalAlignment="Top"/>

        <TextBox x:Name="totalRecordsTextBox" HorizontalAlignment="Left" Margin="100,14,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="195"/>
        <TextBox x:Name="totalAgeTextBox" HorizontalAlignment="Left" Margin="100,37,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="195"/>
        <local:panel HorizontalAlignment="Center" Margin="0,64,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
