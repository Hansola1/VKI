<UserControl x:Class="CreatUserControl_2.usState"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CreatUserControl_2"
          
             mc:Ignorable="d" d:DesignWidth="300" Height="43">
    <Grid x:Name="ucState" Background="#FFB2ADFC">
        <Label Content="State:" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cboState" HorizontalAlignment="Left"  VerticalAlignment="Top" Width="242" Height="24" Margin="48,12,0,0"
                  Loaded="usState_Loaded" />
        <Border BorderBrush="Black" BorderThickness="1"/>

    </Grid>
</UserControl>
