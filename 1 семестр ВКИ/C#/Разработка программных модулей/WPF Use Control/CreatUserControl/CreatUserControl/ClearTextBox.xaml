<UserControl x:Class="CreatUserControl.ClearTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CreatUserControl"
             mc:Ignorable="d" 
             d:DesignHeight="53" d:DesignWidth="191">
    <Grid x:Name="lblLastName" Width="191" Height="53" Background="#FFE5BDFF">
        <Label x:Name="lblTitle" Content="Пишем и убираем ;)" HorizontalAlignment="Left" Margin="3,5,0,0" VerticalAlignment="Top" RenderTransformOrigin="-1.369,0.547" FontFamily="Bahnschrift" Foreground="White" >
        </Label>
        <TextBox x:Name="txtValue" HorizontalAlignment="Left" Margin="3,23,0,0" TextWrapping="Wrap" VerticalAlignment="Center" Width="148" Height="23" Background="White"/>
        <Button x:Name="btnClear" Content="↻" HorizontalAlignment="Left" Margin="156,26,0,0" VerticalAlignment="Top" Width="31" Height="24" Background="#FFC98BFF" Click="btnClear_Click"/>

    </Grid>
</UserControl>
