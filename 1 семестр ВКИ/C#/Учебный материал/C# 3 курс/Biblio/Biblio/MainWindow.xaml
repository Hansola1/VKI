<Window x:Class="Biblio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Biblio"
        mc:Ignorable="d"
        Title="Библиотека" Height="450" Width="800">
    <Grid>
        <TabControl>

            <TabItem Header="Каталог книг">
                <ListView Name="ListBooks" Background="LightGray">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Артикул" DisplayMemberBinding="{Binding Id}" Width="50"/>
                            <GridViewColumn Header="Автор" DisplayMemberBinding="{Binding Author}" Width="200"/>
                            <GridViewColumn Header="Название" DisplayMemberBinding="{Binding Title}" Width="250"/>
                            <GridViewColumn Header="Год издания" DisplayMemberBinding="{Binding PubYear}" Width="100"/>
                            <GridViewColumn Header="Количество экземляров" DisplayMemberBinding="{Binding CountCopies}" Width="200"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>

            <TabItem Header="Добавить книгу">
                <Canvas Background="LightGray" Height="auto" Width="auto">

                    <TextBlock Background="blue" Canvas.Left="10" Canvas.Top="10" Height="25" Width="50"
                               Name="BookInfoTextBlokcId" Text="Id" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <TextBox Name="NewBookId" Height="25" Width="50" 
                             Canvas.Left="10" Canvas.Top="40" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                    <TextBlock Background="blue" Canvas.Left="78" Canvas.Top="10" Height="26" Width="150"
                               Name="BookInfoTextBlokcAuthor" Text="Автор" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <TextBox Name="NewBookAuthor" Height="26" Width="150" 
                             Canvas.Left="78" Canvas.Top="40" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                    <TextBlock Background="blue" Canvas.Left="247" Canvas.Top="10" Height="25" Width="150"
                               Name="BookInfoTextBlokcTitle" Text="Название" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <TextBox Name="NewBookTitle" Height="25" Width="150" 
                             Canvas.Left="247" Canvas.Top="40"/>

                    <TextBlock Background="blue" Canvas.Left="414" Canvas.Top="9" Height="26" Width="112"
                               Name="BookInfoTextBlokcPubYear" Text="Год издания" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBox Name="NewBookPubYear" Height="25" Width="112" 
                             Canvas.Left="414" Canvas.Top="40" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                    <TextBlock Background="blue" Canvas.Left="545" Canvas.Top="10" Height="26" Width="150"
                               Name="BookInfoTextBlokcCountCopies" Text="Количество экземляров" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBox Name="NewBookCountCopies" Height="25" Width="150" 
                             Canvas.Left="545" Canvas.Top="40" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                    <Button Name="AddNewBookButton" Background="blue" Content="Добавить" 
                            Canvas.Left="708" Height="55" Width="62" Canvas.Top="10"
                            Click="NewBookClick" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Name="AddNewBookTextBlokc" Background="blue" HorizontalAlignment="Left" 
                               Height="Auto" VerticalAlignment="Top" Canvas.Left="10" Canvas.Top="82"
                               Width="Auto"  />
                </Canvas>
            </TabItem>

            <TabItem Header="Поиск книги">
                <Canvas Background="LightGray" Height="auto" Width="auto">
                    <ComboBox Name="Choose" Canvas.Left="10" Canvas.Top="5" Width="150">
                        <TextBlock FontSize="12">Артикул</TextBlock>
                        <TextBlock FontSize="12">Автор</TextBlock>
                        <TextBlock FontSize="12">Название</TextBlock>
                    </ComboBox>
                    <TextBox Name="FindBookInput" Height="25" Width="100" 
                             Canvas.Left="230" Canvas.Top="35"/>
                    <Button Name="BooksSearchButton" Background="blue" Content="Поиск" 
                            Canvas.Left="170" Height="25" Width="50" Canvas.Top="35"
                            Click="SearchBooksClick" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Background="blue" Canvas.Left="170" Canvas.Top="70" Height="Auto" Width="Auto"  
                               Name="BookInfoTextBlokc" Text=""/>
                </Canvas>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
