<Window x:Class="MusMorningProject.alarmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusMorningProject"
        mc:Ignorable="d"
        Title="" Height="800" Width="360">

    <Grid Background="#FFBF1A">
        <TextBox HorizontalAlignment="Center" Margin="0,202,0,0" TextWrapping="Wrap" Text="Введите название" VerticalAlignment="Top" Width="340" Height="63"/>
        <Label Content="12:00:00" HorizontalAlignment="Center" Margin="0,85,0,0" VerticalAlignment="Top" FontSize="48" Foreground="White"/>
        <Label Content="Настройки будильника" HorizontalAlignment="Center" Margin="0,23,0,0" VerticalAlignment="Top" FontSize="24" Foreground="White"/>
        <RadioButton Content="ПН" HorizontalAlignment="Left" Margin="10,289,0,0" VerticalAlignment="Top" Foreground="White"/>
        <RadioButton Content="ВТ" HorizontalAlignment="Left" Margin="65,289,0,0" VerticalAlignment="Top" Foreground="White"/>
        <RadioButton Content="СР" HorizontalAlignment="Left" Margin="109,289,0,0" VerticalAlignment="Top" Foreground="White"/>
        <RadioButton Content="ЧТ" HorizontalAlignment="Left" Margin="154,289,0,0" VerticalAlignment="Top" Background="White" Foreground="White"/>
        <RadioButton Content="ПТ" HorizontalAlignment="Left" Margin="199,289,0,0" VerticalAlignment="Top" Foreground="White"/>
        <RadioButton Content="СБ" HorizontalAlignment="Left" Margin="245,289,0,0" VerticalAlignment="Top" Foreground="White"/>
        <RadioButton Content="ВСК" HorizontalAlignment="Left" Margin="290,289,0,0" VerticalAlignment="Top" Foreground="White"/>
        <Button Content="Добавить" HorizontalAlignment="Left" Margin="10,362,0,0" VerticalAlignment="Top" Height="55" Width="119" BorderBrush="#FF616161" Background="White"/>
        <Button Content="Назад" HorizontalAlignment="Left" Margin="227,362,0,0" VerticalAlignment="Top" Height="55" Width="123" Click="Button_Click" Background="White"/>

    </Grid>
</Window>
 