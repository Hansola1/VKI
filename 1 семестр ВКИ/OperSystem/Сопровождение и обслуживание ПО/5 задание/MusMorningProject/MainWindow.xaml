<Window x:Class="MusMorningProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusMorningProject"
        mc:Ignorable="d" 
        Title="MusMorning" Height="800" Width="360">
    <Grid>
        <TabControl>

            <TabItem Header="Секундомер" Margin="-2,-2,-19,0" Background="#FFBF1A" Foreground="Black" OpacityMask="#FFE49E">
                <Grid Background="#FFBF1A">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="0*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="" HorizontalAlignment="Center" Margin="0,386,0,0" VerticalAlignment="Top" Height="73" Width="186" Background="White"/>
                    <Label Content="12:00:00" HorizontalAlignment="Center" Margin="0,202,0,0" VerticalAlignment="Top" FontSize="48" Foreground="White"/>
                </Grid>
            </TabItem>


            <TabItem Header="Будильник" Margin="19,-3,-38,1" Background="#FFBF1A" Foreground="Black" OpacityMask="#FFE49E">
                <Grid Background="#FFBF1A">
                    <ListBox Margin="0,10,0,120"/>
                    <Button Content="" HorizontalAlignment="Center" Margin="0,643,0,0" VerticalAlignment="Top" Height="68" Width="158" Background="White"/>
                </Grid>
            </TabItem>


            <TabItem Header="Мир.время" Margin="39,-2,-39,0" Background="#FFBF1A" Foreground="Black" OpacityMask="#FFE49E">
                <Grid Background="#FFBF1A">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="224*"/>
                        <ColumnDefinition Width="131*"/>
                    </Grid.ColumnDefinitions>
                    <ListBox Margin="0,262,0,136" Grid.ColumnSpan="2"/>
                    <Label Content="12:00:00" HorizontalAlignment="Left" Margin="84,137,0,0" VerticalAlignment="Top" FontSize="48" Background="{x:Null}" Foreground="White" Grid.ColumnSpan="2"/>
                    <Button Content="" HorizontalAlignment="Left" Margin="109,620,0,0" VerticalAlignment="Top" Height="75" Width="136" Grid.ColumnSpan="2" Background="White"/>
                </Grid>


            </TabItem>
        </TabControl>

    </Grid>
</Window>
