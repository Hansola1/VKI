        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SunMorningDesign_"
        mc:Ignorable="d"
        Title="Window1" Height="1280" Width="1024">
    <Grid HorizontalAlignment="Left" Width="1024" Height="1280"
          Background="Orange"      
          >
        <TabControl>
            <TabItem Header="Секундомер"  FontSize="43">
                <Grid Background="#FFE5E5E5" Margin="15,15,15,15">
                    <Button Content="Button" HorizontalAlignment="Center" Margin="0,850,0,0" VerticalAlignment="Top" Height="163" Width="558"/>
                    <Ellipse HorizontalAlignment="Center" Height="610" Margin="0,121,0,0" Stroke="Black" VerticalAlignment="Top" Width="616"/>
                    <Label Content="00:00:00" HorizontalAlignment="Center" FontSize="90" Margin="0,356,0,0" VerticalAlignment="Top" Height="140" Width="344" RenderTransformOrigin="0.462,0.211"/>
                </Grid>
            </TabItem>
            <TabItem Header="Будильник"  FontSize="43" >
                <Grid Background="#FFE5E5E5" Margin="15,0,15,0" Height="1168">
                    <Label Content="Звонок через 8 часов 15 минут" HorizontalAlignment="Left" Margin="10,-5,0,0" VerticalAlignment="Top"/>
                    <TextBox HorizontalAlignment="Center" Margin="0,92,0,0" TextWrapping="Wrap" Text="TextBox                                                                  :" VerticalAlignment="Top" Width="968" Height="101"/>
                    <TextBox HorizontalAlignment="Center" Margin="0,220,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="968" Height="101"/>
                    <TextBox HorizontalAlignment="Center" Margin="0,350,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="968" Height="101"/>
                    <TextBox HorizontalAlignment="Center" Margin="0,483,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="968" Height="101"/>
                    <Button Content="Button" HorizontalAlignment="Center" Margin="0,918,0,0" VerticalAlignment="Top" Height="163" Width="558"/>
               
                    <!--<ListBox d:ItemsSource="{d:SampleData ItemCount=0}" Margin="0,67,0,10"/> -->
                </Grid>
            </TabItem>
            <TabItem Header="Мировое время"  FontSize="43" >





                <Grid Background="#FFE5E5E5" Margin="15,15,15,15">
                    <Label Content="12:00:00" HorizontalAlignment="Left" Margin="214,256,0,0" VerticalAlignment="Top" FontSize="140"/>
                    <TextBox HorizontalAlignment="Center" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Center" Width="968" Height="141"/>
                    <TextBox HorizontalAlignment="Center" Margin="0,690,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="968" Height="127"/>
                    <TextBox HorizontalAlignment="Center" Margin="0,856,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="968" Height="127"/>
                    <Button Content="Button" HorizontalAlignment="Center" Margin="0,1012,0,0" VerticalAlignment="Top" Height="127" Width="488"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
