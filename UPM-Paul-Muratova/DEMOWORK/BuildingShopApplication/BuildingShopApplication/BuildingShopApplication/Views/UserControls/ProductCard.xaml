<UserControl x:Class="BuildingShopApplication.Views.UserControls.ProductCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BuildingShopApplication.Views.UserControls"
             mc:Ignorable="d" 
            d:DesignHeight="200" d:DesignWidth="750" Width="750" Height="200"
             FontFamily="Comic Sans MS" Background="White">

    <Border BorderThickness="1" BorderBrush="Black" Padding="10" Margin="5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="365"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <!-- Информация -->
            <Border BorderThickness="1" BorderBrush="Black" Padding="10">
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="{Binding Article, StringFormat='Артикул: {0}'}" FontSize="12" TextWrapping="Wrap" Margin="0,3,0,0"/>
                    <TextBlock Text="{Binding Description, StringFormat='Описание товара: {0}'}" FontSize="12" TextWrapping="Wrap" Margin="0,3,0,0"/>
                    <TextBlock Text="{Binding Manufacturer, StringFormat='Производитель: {0}'}" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Основная информация -->
            <Border BorderThickness="1" BorderBrush="Black" Padding="10" Grid.Column="1" Margin="5,0,0,0">
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="{Binding Cost, StringFormat='Цена: {0:C}'}" FontSize="13" FontWeight="SemiBold" Foreground="DarkGreen" Margin="0,5,0,0"/>
                    <TextBlock Text="{Binding StockQuantity, StringFormat='Количество(Наличие) на складе: {0}'}" FontSize="11" Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding MaxDiscount, StringFormat='Cкидка: {0}%'}"
                           TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Фото -->
            <Border BorderThickness="1" BorderBrush="Black" Padding="10" Grid.Column="2" Margin="5,0,0,0">
                <Image Source="{Binding FullImagePath}" Stretch="UniformToFill" MaxWidth="90" MaxHeight="90"
                    HorizontalAlignment="Center" VerticalAlignment="Top"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
