<Page x:Class="BuildingShopApplication.Views.UserControls.AddEditProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BuildingShopApplication.Views.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" FontFamily="Comic Sans MS">

    <Grid Height="450" Width="800" Background="#FF76E383">
        <!--<Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>-->

        <!--Заголовок-->
        <TextBlock HorizontalAlignment="Left" Margin="165,34,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="502" FontSize="26"
                   x:Name="LabelPage" Height="51"><Run Language="ru-ru" Text=""/></TextBlock>

        <!--Кнопки-->
        <Button Click="Cancel_click"  Content="Назад" HorizontalAlignment="Left" Margin="237,408,0,0" VerticalAlignment="Top" Width="131" FontSize="20" Height="32" Foreground="Black" Background="#FF498C51"/>
        <Button Content="Сохранить" HorizontalAlignment="Left" Margin="400,408,0,0" VerticalAlignment="Top" Width="150" Click="Save_click"   FontSize="20" Height="32" Foreground="Black" Background="#FF498C51"/>

        <Label x:Name="NameAccount" HorizontalAlignment="Left" Margin="483,13,0,0" VerticalAlignment="Top" Width="297" FontSize="16" Height="16"/>

        <!--Поля -->
        <!--<TextBlock HorizontalAlignment="Left" Margin="127,48,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="20"   Width="152"><Run Language="ru-ru" Text="Фото продукта"/></TextBlock>
        <TextBox x:Name="PhotoTextBox" HorizontalAlignment="Left" Margin="274,48,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="322" Height="27"  />-->

        <TextBlock HorizontalAlignment="Left" Margin="59,90,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="20" Width="219"  ><Run Language="ru-ru" Text="Наименование товара"/></TextBlock>
        <TextBox x:Name="NameTextBox" HorizontalAlignment="Left" Margin="274,90,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="322" Height="27"  />

        <TextBlock HorizontalAlignment="Left" Margin="111,130,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="20"  ><Run Language="ru-ru" Text="Категория товара"/></TextBlock>
        <ComboBox x:Name="CategoryProductComboBox" HorizontalAlignment="Left" Margin="274,132,0,0" VerticalAlignment="Top" Width="322"/>

        <TextBlock HorizontalAlignment="Left" Margin="111,164,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="20"  ><Run Language="ru-ru" Text="Описание товара"/></TextBlock>
        <TextBox x:Name="DescriptiontTextBox" HorizontalAlignment="Left" Margin="274,164,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="322" Height="22"  />

        <TextBlock HorizontalAlignment="Left" Margin="111,200,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="20"   Height="25"><Run Language="ru-ru" Text="Производитель"/></TextBlock>
        <ComboBox x:Name="ManufactureComboBox" HorizontalAlignment="Left" Margin="274,200,0,0" VerticalAlignment="Top" Width="322" Height="25"/>

        <TextBlock HorizontalAlignment="Left" Margin="111,264,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="20"  ><Run Language="ru-ru" Text="Цена товара"/></TextBlock>
        <TextBox x:Name="PriceTextBox" HorizontalAlignment="Left" Margin="274,265,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="322" Height="22"  />


        <TextBlock HorizontalAlignment="Left" Margin="86,297,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="20" ><Run Language="ru-ru" Text="Кол-во на складе"/></TextBlock>
        <TextBox x:Name="CountTextBox" HorizontalAlignment="Left" Margin="274,298,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="322" Height="25"  />

        <TextBlock HorizontalAlignment="Left" Margin="111,343,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="20" ><Run Language="ru-ru" Text="Скидка"/></TextBlock>
        <TextBox x:Name="DiscountTextBox" HorizontalAlignment="Left" Margin="274,342,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="322" Height="23"/>

        <TextBlock HorizontalAlignment="Left" Margin="111,230,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="20" Text="Поставщик"/>
        <ComboBox x:Name="ProviderComboBox" HorizontalAlignment="Left" Margin="274,230,0,0" VerticalAlignment="Top" Width="322" Height="23"/>

        <TextBlock HorizontalAlignment="Left" Margin="73,365,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="20" Text="Единица измерения"/>
        <TextBox x:Name="MeasurementUnitTextBox" HorizontalAlignment="Left" Margin="274,370,0,0" VerticalAlignment="Top" Width="322" Height="23"/>
    </Grid>
</Page>