<Page x:Class="BuildingShopApplication.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BuildingShopApplication.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage" FontFamily="Comic Sans MS">

    <Grid Background="White">
        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Panel.ZIndex="1"></Frame>

        <TextBlock HorizontalAlignment="Left" Margin="373,122,0,0" TextWrapping="Wrap" Text="Вход" VerticalAlignment="Top" FontSize="35" />
        <!--<Image Source="/Resource/Icon/Логотип.png" Height="60" Width="60" Margin="380,37,360,353"/>-->

        <TextBox x:Name="loginTextBox" HorizontalAlignment="Left" Margin="273,190,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="298" Height="32"/>
        <TextBox x:Name="passwordTextBox" HorizontalAlignment="Left" Margin="273,248,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="298" Height="32"/>

        <TextBlock HorizontalAlignment="Left" Margin="185,187,0,0" TextWrapping="Wrap" Text="Логин" VerticalAlignment="Top" FontSize="25" />
        <TextBlock HorizontalAlignment="Left" Margin="176,245,0,0" TextWrapping="Wrap" Text="Пароль" VerticalAlignment="Top" FontSize="25" />

        <Button Content="Войти" HorizontalAlignment="Left" Margin="273,320,0,0" VerticalAlignment="Top" Height="33" Width="298" Click="ToProduct_Click"/>
    </Grid>
</Page>
